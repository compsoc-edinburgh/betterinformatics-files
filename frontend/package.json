{
  "name": "frontend",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "dependencies": {
    "@grafana/faro-react": "^1.19.0",
    "@mantine/colors-generator": "^8.0.0",
    "@mantine/core": "^8.0.0",
    "@mantine/hooks": "^8.0.0",
    "@tabler/icons-react": "^3.0.0",
    "ahooks": "^2.10.14",
    "chroma-js": "^2.4.2",
    "clsx": "^2.1.0",
    "date-fns": "^4.0.0",
    "jszip": "^3.10.0",
    "katex": "^0.16.9",
    "lodash-es": "^4.17.21",
    "pdfjs-dist": "^5.5.207",
    "query-string": "^7.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "6.30.3",
    "react-syntax-highlighter": "^15.5.0",
    "react-transition-group": "^4.4.5",
    "rehype-katex": "^7.0.0",
    "rehype-mermaid": "^3.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "use-query-params": "2.2.2",
    "vite": "^8.0.1",
    "vite-plugin-svgr": "^4.5.0"
  },
  "scripts": {
    "start-docker": "vite --no-open --host 0.0.0.0",
    "start": "vite",
    "start-with-faro": "VITE_FARO_DISABLE=false vite",
    "build": "tsc && vite build",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css}\"",
    "check-format": "prettier --list-different \"src/**/*.{js,jsx,ts,tsx,json,css}\"",
    "lint": "yarn run eslint \"src/**/*.{js,jsx,ts,tsx}\""
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/runtime": "^7.20.0",
    "@eslint/js": "^9.38.0",
    "@types/katex": "^0.16.6",
    "@types/lodash-es": "^4.17.5",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-router-dom": "^5.3.0",
    "@types/react-syntax-highlighter": "^15.0.0",
    "@types/react-transition-group": "^4.4.1",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.38.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.0",
    "globals": "^16.4.0",
    "postcss": "^8.4.35",
    "postcss-preset-mantine": "^1.13.0",
    "postcss-simple-vars": "^7.0.1",
    "prettier": "^3.1.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.1"
  }
}
